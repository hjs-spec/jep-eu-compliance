{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jep-eu-compliance.org/schemas/medical.schema.json",
  "title": "JEP EU Compliance — Medical Diagnosis Extension",
  "description": "JSON Schema for JEP events in medical diagnosis under EU AI Act Annex III (1)(a) and Annex I (MDR/IVDR).",
  "type": "object",
  "properties": {
    "diagnosis_code": {
      "type": "string",
      "description": "ICD-11 or SNOMED CT code",
      "examples": ["ICD-11:2A00", "SNOMED:254637007"]
    },
    "input_data_hash": {
      "type": "string",
      "description": "Multihash of raw input (imaging, lab, EHR)",
      "pattern": "^(sha256|sm3):[a-fA-F0-9]+$",
      "examples": ["sha256:a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456"]
    },
    "confidence_score": {
      "type": "number",
      "description": "Model confidence score, 0.0 to 1.0",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "human_review_required": {
      "type": "boolean",
      "description": "True for Annex III high-risk systems"
    },
    "human_reviewer_did": {
      "type": ["string", "null"],
      "description": "DID of reviewing clinician (ephemeral or salted)"
    },
    "model_version_hash": {
      "type": "string",
      "description": "Hash of model version manifest",
      "pattern": "^(sha256|sm3):[a-fA-F0-9]+$"
    },
    "mdr_class": {
      "type": ["string", "null"],
      "description": "MDR/IVDR classification if Annex I applicable",
      "enum": ["I", "IIa", "IIb", "III", null]
    },
    "post_market_monitoring_id": {
      "type": "string",
      "description": "Reference to post-market surveillance plan (Art. 72)"
    }
  },
  "required": [
    "diagnosis_code",
    "input_data_hash",
    "confidence_score",
    "human_review_required",
    "model_version_hash",
    "post_market_monitoring_id"
  ],
  "if": {
    "properties": {
      "human_review_required": { "const": true }
    }
  },
  "then": {
    "required": ["human_reviewer_did"]
  },
  "additionalProperties": false
}