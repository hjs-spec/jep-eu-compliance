{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jep-eu-compliance.org/schemas/critical-infra.schema.json",
  "title": "JEP EU Compliance — Critical Infrastructure Extension",
  "description": "JSON Schema for JEP events in critical infrastructure under EU AI Act Annex III (2).",
  "type": "object",
  "properties": {
    "infra_type": {
      "type": "string",
      "description": "Type of critical infrastructure",
      "enum": ["energy_grid", "water_supply", "transport", "digital_infra"]
    },
    "system_state_hash": {
      "type": "string",
      "description": "Hash of SCADA/OT system state snapshot",
      "pattern": "^(sha256|sm3):[a-fA-F0-9]+$"
    },
    "command_type": {
      "type": "string",
      "description": "Classification of AI command"
    },
    "operator_did": {
      "type": "string",
      "description": "DID of supervising human operator"
    },
    "cybersecurity_threat_level": {
      "type": "string",
      "description": "Current cybersecurity threat level",
      "enum": ["none", "low", "medium", "high", "critical"]
    },
    "physical_safety_impact": {
      "type": "string",
      "description": "Potential physical safety impact",
      "enum": ["none", "minor", "major", "catastrophic"]
    },
    "redundancy_activated": {
      "type": "boolean",
      "description": "True if fallback system engaged"
    },
    "safe_state_available": {
      "type": "boolean",
      "description": "True if safe-state transition possible"
    },
    "nist_csf_alignment": {
      "type": ["string", "null"],
      "description": "NIST CSF or equivalent framework reference"
    }
  },
  "required": [
    "infra_type",
    "system_state_hash",
    "command_type",
    "operator_did",
    "cybersecurity_threat_level",
    "physical_safety_impact",
    "safe_state_available"
  ],
  "additionalProperties": false
}